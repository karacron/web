generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model WaitlistSignup {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  type              String   // "personal" or "company"
  companyName       String?
  employeeRange     String?  // "1-10", "11-50", etc.
  message           String
  consentPrivacy    Boolean  @default(false)
  locale            String   @default("es")
  ipHash            String?  // SHA256 hash of IP for rate limiting
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([createdAt])
  @@index([ipHash])
}
